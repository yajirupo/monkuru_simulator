; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="monkuru_simulator"
config/description="モンスターくるくるのシミュレータ"
run/main_scene="res://scenes/Main/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://vh6b6o4thhq3"

[autoload]

Enums="*res://autoload/Enums.gd"
Constants="*res://autoload/Constants.gd"
GameState="*res://autoload/GameState.gd"
GameData="*res://autoload/GameData.gd"
PlayerIni="*res://autoload/PlayerIni.gd"
KeyInput="*res://autoload/KeyInput.gd"
ImageManager="*res://autoload/ImageManager.gd"
SoundManager="*res://autoload/SoundManager.gd"
GameInit="*res://autoload/GameInit.gd"
ReplayManager="*res://autoload/ReplayManager.gd"
VsReplayManager="*res://autoload/VsReplayManager.gd"
VsComReplayManager="*res://autoload/VsComReplayManager.gd"
OnlineReplayManager="*res://autoload/OnlineReplayManager.gd"
NetworkManager="*res://autoload/NetworkManager.gd"

[debug]

gdscript/warnings/narrowing_conversion=0

[display]

window/size/viewport_width=640
window/size/viewport_height=480
window/size/resizable=false
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
